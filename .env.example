# Email Intelligence Platform — environment template
# ---------------------------------------------------
# Copy to ".env" and fill in. Every value here is OPTIONAL — config.py ships
# sensible defaults. Real environment variables override this file.
#
#   cp .env.example .env

# ── Gmail (IMAP) ───────────────────────────────────────────────────────────────
# Use a Google "App Password" (16 chars), NOT your normal password.
GMAIL_EMAIL=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here
IMAP_SERVER=imap.gmail.com
MAX_EMAILS=10

# ── Local LLM (Ollama) ─────────────────────────────────────────────────────────
# Supported models: llama3 | gemma3 | mistral
# The platform runs fully WITHOUT Ollama — LLM features simply show as
# unavailable. To enable them: install Ollama and `ollama pull llama3`.
LLM_PROVIDER=ollama
LLM_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434
LLM_TIMEOUT=60
LLM_TEMPERATURE=0.2
LLM_ENABLED=true
LLM_CACHE_ENABLED=true

# ── Embeddings / RAG ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32
CHROMA_COLLECTION=emails
RAG_TOP_K=5

# ── Paths (override only if you want non-default locations) ─────────────────────
# MODEL_PATH=models/sentiment_model.pkl
# DB_PATH=db/email_analysis.db
# CHROMA_DIR=db/chroma

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=WARNING
